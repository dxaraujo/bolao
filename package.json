{
	"name": "bolao",
	"version": "1.0.0",
	"private": true,
	"description": "Bolão da Copa do Mundo — frontend (React/Vite) + backend (NestJS) + shared (@bolao/shared).",
	"scripts": {
		"dev": "pnpm -r --parallel --aggregate-output --reporter=append-only dev",
		"dev:frontend": "pnpm --filter ./frontend dev",
		"dev:backend": "pnpm --filter ./backend start:dev",
		"dev:shared": "pnpm --filter @bolao/shared dev",
		"build": "pnpm -r --stream --workspace-concurrency=1 build",
		"build:shared": "pnpm --filter @bolao/shared build",
		"build:frontend": "pnpm --filter ./frontend build",
		"build:backend": "pnpm --filter ./backend build",
		"format": "pnpm -r --parallel format",
		"format:check": "pnpm -r --parallel format:check",
		"install:all": "pnpm install"
	},
	"engines": {
		"node": ">=20.11"
	},
	"packageManager": "pnpm@11.1.3",
	"dependencies": {
		"pnpm": "^11.1.3"
	}
}
